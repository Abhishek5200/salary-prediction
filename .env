# IBM Cloud API Key
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# Watson Machine Learning credentials
WML_URL=https://us-south.ml.cloud.ibm.com
WML_INSTANCE_ID=your_wml_instance_id_here

# Watson Assistant credentials
WATSON_ASSISTANT_API_KEY=your_watson_assistant_api_key_here
WATSON_ASSISTANT_URL=your_watson_assistant_url_here
WATSON_ASSISTANT_ID=your_watson_assistant_id_here

# IBM Cloud Object Storage (optional)
COS_API_KEY=your_cos_api_key_here
COS_INSTANCE_ID=your_cos_instance_id_here

# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=True